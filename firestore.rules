rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role (superadmin|admin|teacher|parent), schoolId
    //
    // Collection: schools
    // Fields: name, ownerId, address, config
    //
    // Collection: students
    // Fields: firstName, lastName, schoolId, parentId, grade, section
    //
    // Collection: grades
    // Fields: studentId, subject, score, term, teacherId
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isSuperAdmin() {
      return hasRole('superadmin') || (request.auth.token.email == "manguitolabsai@gmail.com" && request.auth.token.email_verified == true);
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isAssistant() {
      return hasRole('assistant');
    }

    function isParent() {
      return hasRole('parent');
    }

    // Rules for Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || isAdmin() || isAssistant());
      allow create: if isAuthenticated() && (isSuperAdmin() || isAdmin() || isAssistant());
      allow update: if isAuthenticated() && (isSuperAdmin() || isAdmin() || (isAssistant() && resource.data.role != 'admin' && resource.data.role != 'superadmin'));
    }

    // Rules for Content
    match /content/{contentId} {
      allow read: if true;
      allow write: if isAuthenticated() && (isSuperAdmin() || isAdmin());
    }

    // Rules for Schools
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Rules for Students
    match /students/{studentId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        isAdmin() || 
        isTeacher() || 
        (isParent() && resource.data.parentId == request.auth.uid)
      );
      allow write: if isSuperAdmin() || isAdmin();
    }

    // Rules for Grades
    match /grades/{gradeId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        isAdmin() || 
        isTeacher() || 
        (isParent() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentId == request.auth.uid)
      );
      allow write: if isSuperAdmin() || isAdmin() || isTeacher();
    }
  }
}
